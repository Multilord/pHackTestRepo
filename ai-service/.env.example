# -----------------------------------------------------------------------
# HomeGrow AI Engine — environment variables
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# -----------------------------------------------------------------------

# Google Gemini API Key — get yours free at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@yourcluster.mongodb.net/?appName=YourApp

# MongoDB database name (default: homegrow)
DB_NAME=homegrow

# Service metadata
AI_SERVICE_NAME=HomeGrow AI Engine
AI_REGION_CONTEXT=Southeast Asia tropical urban gardening

# Port this FastAPI service listens on
PORT=8000
