# Gemini API Key — get yours free at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (gemini-2.0-flash is fast and free-tier friendly)
GEMINI_MODEL=gemini-2.0-flash

# Person D's Express backend URL (reference only — AI service does not call this)
BACKEND_URL=http://localhost:3000

# Service metadata
AI_SERVICE_NAME=HomeGrow AI Engine
AI_REGION_CONTEXT=Southeast Asia tropical urban gardening

# Port this FastAPI service listens on
PORT=8000
MONGODB_URI=mongodb+srv://<username>:<password>@yourcluster.mongodb.net/?appName=YourApp
